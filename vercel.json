{
  "version": 2,
  "cleanUrls": true,
  "buildCommand": "vite build",
  "outputDirectory": "dist/client",
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/api/entry"
    }
  ]
}
